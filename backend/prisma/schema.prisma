generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VOLUNTEER
  ORGANIZER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  avatarUrl String?
  bio       String?
  role      Role     @default(VOLUNTEER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  needs         Need[]        @relation("OrganizerNeeds")
  responses     Application[] @relation("VolunteerResponses")
  givenReviews  Review[]      @relation("GivenReviews")
  receivedReviews Review[]    @relation("ReceivedReviews")
}

model Review {
  id          String   @id @default(uuid())
  rating      Int
  comment     String?
  needId      String
  need        Need     @relation(fields: [needId], references: [id], onDelete: Cascade)
  reviewerId  String
  reviewer    User     @relation("GivenReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId  String
  reviewee    User     @relation("ReceivedReviews", fields: [revieweeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model InviteCode {
  id        String   @id @default(uuid())
  code      String   @unique
  isUsed    Boolean  @default(false)
  usedBy    String?
  createdAt DateTime @default(now())
  expiresAt DateTime @default(now())
}

model Need {
  id          String        @id @default(uuid())
  title       String
  description String
  status      String        @default("OPEN") // OPEN, IN_PROGRESS, CLOSED, HIDDEN
  location    String        @default("")
  time        String        @default("")
  organizerId String
  organizer   User          @relation("OrganizerNeeds", fields: [organizerId], references: [id], onDelete: Cascade)
  applications Application[]
  reviews     Review[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Application {
  id          String   @id @default(uuid())
  needId      String
  need        Need     @relation(fields: [needId], references: [id], onDelete: Cascade)
  volunteerId String
  volunteer   User     @relation("VolunteerResponses", fields: [volunteerId], references: [id], onDelete: Cascade)
  options     String[] // Навички/ресурси, обрані волонтером
  message     String?  // Коментар волонтера
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())
}
